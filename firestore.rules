rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: stats
    // Document ID: {slug}
    // Fields:
    //   - slug: string (required)
    //   - views: number
    //   - clicks: number
    //   - impressions: number
    //   - updatedAt: string (ISO 8601)
    //
    // Collection: admin_config
    // Document ID: {key}
    // Fields:
    //   - key: string (required)
    //   - value: string (required)
    //
    // Collection: indexing_status
    // Document ID: {slug}
    // Fields:
    //   - slug: string (required)
    //   - google_status: string
    //   - naver_status: string
    //   - updatedAt: string (ISO 8601)
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // For this app, we use session-based admin auth in Express (server-side).
      // However, Firestore rules also need to know who can write.
      // We'll allow the bootstrapped admin email defined in server.ts.
      return isAuthenticated() && 
             (request.auth.token.email == "luganopizza@gmail.com" && request.auth.token.email_verified == true);
    }

    // Stats collection: Public can increment (create/update), but not read or delete (only Admin can read)
    match /stats/{slug} {
      allow read: if isAdmin();
      allow create, update: if true; // In a production app, we'd limit this further, but server-side proxy handles most logic
    }

    // Admin config: Only Admin can read/write
    match /admin_config/{key} {
      allow read, write: if isAdmin();
    }

    // Indexing status: Only Admin can read/write
    match /indexing_status/{slug} {
      allow read, write: if isAdmin();
    }
  }
}
